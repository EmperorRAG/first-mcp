{
	"name": "coffee-mate",
	"version": "1.0.0",
	"description": "",
	"type": "module",
	"main": "build/main.js",
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"test": "vitest run",
		"test:unit": "vitest run --project unit",
		"test:component": "vitest run --project component",
		"test:service": "vitest run --project service",
		"test:domain": "vitest run --project domain",
		"test:feature": "vitest run --project component --project service --project domain",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"docs": "typedoc && remark docs/api --output --quiet",
		"docs:lint": "remark docs/api --quiet --frail",
		"lint:md": "remark . --quiet --frail",
		"format:md": "remark . --output",
		"lint:ts": "eslint",
		"fix:ts": "eslint --fix"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"@cfworker/json-schema": "^4.1.1",
		"@modelcontextprotocol/express": "^2.0.0-alpha.2",
		"@modelcontextprotocol/node": "^2.0.0-alpha.2",
		"@modelcontextprotocol/server": "^2.0.0-alpha.2",
		"cors": "^2.8.6",
		"express": "^5.2.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@modelcontextprotocol/client": "^2.0.0-alpha.2",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.0",
		"@types/node": "^22.14.1",
		"eslint": "^10.2.0",
		"jiti": "^2.6.1",
		"pixelmatch": "^7.1.0",
		"quickpickle": "^1.11.1",
		"remark-cli": "^12.0.1",
		"remark-lint-unordered-list-marker-style": "^4.0.1",
		"remark-preset-lint-consistent": "^6.0.1",
		"remark-preset-lint-recommended": "^7.0.1",
		"typedoc": "^0.28.18",
		"typedoc-plugin-markdown": "^4.11.0",
		"typedoc-plugin-remark": "^2.0.1",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.58.1",
		"vitest": "^4.1.4"
	},
	"files": [
		"build"
	]
}